<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/NexoraCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="@color/ripple_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivMediaThumb"
            android:layout_width="@dimen/media_thumb_size"
            android:layout_height="@dimen/media_thumb_size"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note"
            android:background="@drawable/bg_album_art"/>

        <!-- Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvMediaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Track Title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvMediaSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="3dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Duration + type icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvMediaDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="@color/text_hint"/>

            <ImageView
                android:id="@+id/ivMediaTypeIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_music_note"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
