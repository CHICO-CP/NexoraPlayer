<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player">

    <!-- Top bar -->
    <ImageButton
        android:id="@+id/btnBackPlayer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvNowPlaying"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="NOW PLAYING"
        android:textSize="11sp"
        android:textColor="@color/nexora_secondary"
        android:gravity="center"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="@id/btnBackPlayer"
        app:layout_constraintBottom_toBottomOf="@id/btnBackPlayer"
        app:layout_constraintStart_toEndOf="@id/btnBackPlayer"
        app:layout_constraintEnd_toStartOf="@id/btnFavorite"/>

    <ImageButton
        android:id="@+id/btnFavorite"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_favorite_border"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/btnBackPlayer"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Album art -->
    <ImageView
        android:id="@+id/ivAlbumArt"
        android:layout_width="@dimen/player_album_art_size"
        android:layout_height="@dimen/player_album_art_size"
        android:src="@drawable/bg_album_art"
        android:scaleType="centerCrop"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackPlayer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Song info -->
    <TextView
        android:id="@+id/tvSongTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Song Title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/ivAlbumArt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvArtistName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Artist Name"
        android:textSize="15sp"
        android:textColor="@color/nexora_secondary"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSongTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Seekbar -->
    <SeekBar
        android:id="@+id/seekbarPlayer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progressTint="@color/nexora_primary"
        android:thumbTint="@color/nexora_primary"
        android:progressBackgroundTint="@color/bg_card"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvArtistName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/seekbarPlayer"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/seekbarPlayer"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Controls -->
    <ImageButton
        android:id="@+id/btnPrev"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_prev"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPlayPause"/>

    <ImageButton
        android:id="@+id/btnPlayPause"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/btn_play_bg"
        android:src="@drawable/ic_play"
        android:padding="14dp"
        app:layout_constraintTop_toTopOf="@id/btnPrev"
        app:layout_constraintBottom_toBottomOf="@id/btnPrev"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnNext"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_next"
        app:layout_constraintTop_toTopOf="@id/btnPrev"
        app:layout_constraintBottom_toBottomOf="@id/btnPrev"
        app:layout_constraintStart_toEndOf="@id/btnPlayPause"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
